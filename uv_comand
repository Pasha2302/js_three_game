# Установка uv:
>> curl -LsSf https://astral.sh/uv/install.sh | sh

## Добавить в PATH fish:
>> echo 'uv generate-shell-completion fish | source' > ~/.config/fish/completions/uv.fish

## Чтобы установить последнюю версию Python:
>> uv python install   

## Для установки конкретной версии для Python:
>> uv python install 3.12

## Для обновления всех установленных версий Python:
>> uv python upgrade

## Это позволит переустановить все ранее установленные версии Python:
>> uv python install --reinstall

## Чтобы обновить версию Python до последнего поддерживаемого патча выпуска:
>> uv python upgrade 3.13

## Для списка установленных и доступных версий Python:
>> uv python list

## Чтобы найти исполняемый Python, используйте uv python findКоманда:
>> uv python find
>> uv python find --system   (Чтобы игнорировать виртуальные среды)

## Дополнительные команды:

    uv cache clean: Удалить записи кэша.
    uv cache prune: Удалить устаревшие записи кэша.
    uv cache dir: Покажите путь каталога uv кэша.
    uv tool dir: Покажите путь каталога uv инструмента.
    uv python dir: Показать установленный uv увиттер Python версии пути.
    uv self update: Обновление uv до последней версии.

